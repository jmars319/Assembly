# Canonical env location for the monorepo is the repo root.
# Preferred env names now use the Assembly product name.
# Legacy Ledger-prefixed names are still accepted temporarily for compatibility.

# Webapp runtime / database
STORAGE_MODE=db # DB mode is recommended for normal webapp development.
DATABASE_URL=
SHADOW_DATABASE_URL= # Optional: used for Prisma migrate diff / shadow DB work.
APP_BASE_URL=http://localhost:3000
PORT=3000

# Workspace API key encryption
ASSEMBLY_KMS_KEY= # Optional until workspace API key encryption is exercised; must be 32 bytes when set.
LEDGER_KMS_KEY= # Legacy fallback. Prefer ASSEMBLY_KMS_KEY.

# GitHub App integration
# Set all GitHub vars together or leave them all unset.
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY_PEM=
GITHUB_APP_SLUG=
GITHUB_APP_URL= # Optional helper for deriving the app slug in helper scripts.

# AI integration
OPENAI_API_KEY= # Optional: used for AI draft/assist flows.
OPENAI_BASE_URL= # Optional: OpenAI-compatible local endpoint, for example http://127.0.0.1:1234/v1.
ASSEMBLY_LOCAL_AI_PROVIDER=off # off | ollama | openai-compatible
ASSEMBLY_LOCAL_AI_BASE_URL=http://127.0.0.1:11434 # Used by ollama or openai-compatible local providers.
ASSEMBLY_LOCAL_AI_MODEL=llama3.2

# Optional smoke-check overrides
ASSEMBLY_SMOKE_EMAIL=
ASSEMBLY_SMOKE_PASSWORD=
LEDGER_SMOKE_EMAIL= # Legacy fallback. Prefer ASSEMBLY_SMOKE_EMAIL.
LEDGER_SMOKE_PASSWORD= # Legacy fallback. Prefer ASSEMBLY_SMOKE_PASSWORD.
